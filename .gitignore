paper_repos/
.python-version
venv/
__pycache__/
.env
.DS_Store

# Machine-specific cluster settings (SSH target, SLURM account, remote paths).
# Committed template: cluster/cluster.env.example.
cluster/cluster.env

# Local design-process artifacts generated by the superpowers tooling
docs/superpowers/

# Code-change walkthroughs (local hand-off notes, regenerable)
docs/walkthroughs/

# Generated dataset corpora live under dataset/<run_name>/ alongside the
# dataset package source. Track the Python package; ignore rendered data.
/dataset/*
!/dataset/*.py

# Pipeline outputs: fitted model checkpoints and eval runs. Regenerable from
# source + corpus, and self-described by eval_summary.json (corpus/checkpoint/
# eval git revisions + sha256), so the bytes need not live in git. Keeps large
# future neural checkpoints (.ckpt/.pt) out of history.
/checkpoints/
/results/

# PyTorch Lightning's default autolog output (metrics.csv + checkpoints per
# run). Regenerable, same rationale as /checkpoints/ and /results/ above.
/lightning_logs/