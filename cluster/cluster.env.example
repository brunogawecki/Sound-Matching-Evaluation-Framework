# Machine-specific cluster settings. Copy to cluster/cluster.env (gitignored) and
# fill in. Sourced as bash by cluster/train.sbatch (on the cluster) and by
# push_corpus.sh / pull_checkpoint.sh (on the laptop). Mirrors the repo's .env
# convention: no value is ever hardcoded in a committed script.
#
#     cp cluster/cluster.env.example cluster/cluster.env   # then edit
#
# Each machine only needs the vars its scripts use — laptop needs CLUSTER_SSH +
# the LOCAL_* paths; the cluster needs CONDA_* + REMOTE_* + TRAINING_CONFIG +
# CHECKPOINT_OUT. Keeping one file with all of them is simplest.

# --- Shared identity ---
# SSH target for the login node (used by the laptop-side transfer scripts).
CLUSTER_SSH=your_login@slurm.cs.put.poznan.pl
# SLURM billing account. Passed as `sbatch -A "$SLURM_ACCOUNT" cluster/train.sbatch`.
SLURM_ACCOUNT=

# --- Cluster-side (read by cluster/train.sbatch) ---
# Miniconda install prefix (the dir that contains etc/profile.d/conda.sh).
CONDA_BASE=$HOME/miniconda3
# Conda env holding the requirements-cluster.txt dependencies.
CONDA_ENV=smef
# Repo checkout on the cluster. The job cd's here before running.
REMOTE_REPO_DIR=$HOME/Sound-Matching-Evaluation-Framework
# Corpus dir on the cluster, passed to fit_model.py --corpus.
REMOTE_CORPUS_DIR=$HOME/corpora/full_preset-gen-vae
# Training config passed to fit_model.py --config (repo-relative or absolute).
TRAINING_CONFIG=cluster/smoke_config.yaml
# Checkpoint path fit_model.py writes (repo-relative or absolute).
CHECKPOINT_OUT=checkpoints/spectrogram_cnn.pt

# --- Laptop-side (read by push_corpus.sh / pull_checkpoint.sh) ---
# Local corpus dir to upload.
LOCAL_CORPUS_DIR=dataset/full_preset-gen-vae
# Local dir to download the checkpoint (and lightning logs) into.
LOCAL_CHECKPOINT_DIR=checkpoints
