# Machine-specific cluster settings. Copy to cluster/cluster.env (gitignored) and edit:
#
#     cp cluster/cluster.env.example cluster/cluster.env
#
# Sourced by train.sbatch (cluster) and push_corpus.sh / pull_checkpoint.sh (laptop);
# fill in one file with every var on both machines. Per-run choices (corpus, model,
# config) are CLI args, not variables here. On the laptop copy, write REMOTE_* as
# literal absolute paths, not $HOME.

# --- Shared ---
CLUSTER_SSH=your_login@slurm.cs.put.poznan.pl
SLURM_ACCOUNT=

# --- Cluster-side (train.sbatch) ---
CONDA_BASE=$HOME/miniconda3                       # dir containing etc/profile.d/conda.sh
CONDA_ENV=smef
REMOTE_REPO_DIR=$HOME/Sound-Matching-Evaluation-Framework   # repo checkout; job cd's here
REMOTE_CORPORA_DIR=$HOME/corpora                            # base dir; corpus name is appended

# Dexed on the compute node — SynthRLi only (D-RL-RENDER); blank for every other family.
# Must be 0.9.8, not 1.0.1 (glibc). Install: cluster/README.md.
DEXED_PATH=                                       # e.g. $HOME/plugins/dexed/dexed-0.9.8-lnx/Dexed.vst3

# --- Experiment tracking (wandb). Only used when the training config sets
#     logger.wandb: true; ignored otherwise. ---
WANDB_API_KEY=            # from https://wandb.ai/authorize
WANDB_ENTITY=             # blank uses your default entity
WANDB_MODE=online         # `offline` if the node has no internet, then `wandb sync`

# --- Laptop-side (push_corpus.sh / pull_checkpoint.sh) ---
LOCAL_CORPORA_DIR=dataset                         # base dir; corpus name is appended
LOCAL_CHECKPOINT_DIR=checkpoints                  # pulls land here, timestamped + a -latest symlink
