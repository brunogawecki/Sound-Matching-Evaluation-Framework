# Machine-specific cluster settings. Copy to cluster/cluster.env (gitignored):
#
#     cp cluster/cluster.env.example cluster/cluster.env   # then edit
#
# Sourced as bash by train.sbatch (cluster) and push_corpus.sh / pull_checkpoint.sh
# (laptop). Fill in one file with every var on both machines — each script reads
# only what it needs. The REMOTE_* paths and CHECKPOINT_OUT must match across copies.

# --- Shared ---
CLUSTER_SSH=your_login@slurm.cs.put.poznan.pl   # SSH target for the login node
SLURM_ACCOUNT=                                   # billing account: sbatch -A "$SLURM_ACCOUNT" ...

# --- Cluster-side (train.sbatch) ---
CONDA_BASE=$HOME/miniconda3                       # dir containing etc/profile.d/conda.sh
CONDA_ENV=smef                                    # env with requirements-cluster.txt installed
REMOTE_REPO_DIR=$HOME/Sound-Matching-Evaluation-Framework   # repo checkout; job cd's here
REMOTE_CORPUS_DIR=$HOME/corpora/full_preset-gen-vae         # corpus; passed to fit_model.py --corpus
MODEL=                                             # required, no default: fit_model.py --model (MeanParameterBaseline | Sound2SynthSpectrogramRegressor)
TRAINING_CONFIG=cluster/smoke_config.yaml         # fit_model.py --config
CHECKPOINT_OUT=checkpoints/spectrogram_cnn.pt     # fit_model.py --out (pick a name matching MODEL)
# NOTE: on the laptop copy, write REMOTE_* as literal absolute paths (/home/your_login/...),
# not $HOME — the transfer scripts source this file locally, so $HOME would be the laptop's.

# --- Laptop-side (push_corpus.sh / pull_checkpoint.sh) ---
LOCAL_CORPUS_DIR=dataset/full_preset-gen-vae      # local corpus to upload
LOCAL_CHECKPOINT_DIR=checkpoints                  # local dir to download the checkpoint into
